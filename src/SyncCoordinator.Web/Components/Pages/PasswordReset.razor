@page "/account/reset"
@attribute [AllowAnonymous]
@layout AuthLayout
@inject IHttpContextAccessor HttpContextAccessor
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Auth_ResetPageTitle"]</PageTitle>

<section class="auth-card">
    <p class="kicker">LOCAL RECOVERY</p>
    <h1>@L["Auth_ResetTitle"]</h1>
    <p>@L["Auth_ResetDescription"]</p>

    @if (!isLocal)
    {
        <div class="message-box error" role="alert">@L["Auth_LocalOnly"]</div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="message-box error" role="alert">@ErrorText(Error)</div>
        }
        <form method="post" action="/auth/reset" class="auth-form">
            <AntiforgeryToken />
            <div class="form-field">
                <label for="reset-password">@L["Auth_NewPassword"]</label>
                <input id="reset-password" class="auth-input" name="password" type="password" minlength="12" maxlength="128" autocomplete="new-password" required autofocus />
                <small>@L["Auth_PasswordRule"]</small>
            </div>
            <div class="form-field">
                <label for="reset-confirmation">@L["Auth_ConfirmPassword"]</label>
                <input id="reset-confirmation" class="auth-input" name="confirmation" type="password" minlength="12" maxlength="128" autocomplete="new-password" required />
            </div>
            <button class="auth-primary danger" type="submit">@L["Auth_ResetAction"]</button>
        </form>
    }
    <p class="auth-footer"><a href="/login">@L["Auth_BackToLogin"]</a></p>
</section>

@code {
    [SupplyParameterFromQuery] private string? Error { get; set; }
    private bool isLocal;

    protected override void OnInitialized() =>
        isLocal = HttpContextAccessor.HttpContext is { } context && LocalRequestGuard.IsLocal(context);

    private string ErrorText(string code) => code switch
    {
        "password_mismatch" => L["Auth_ErrorMismatch"],
        "password_too_short" => L["Auth_ErrorTooShort"],
        "password_too_long" => L["Auth_ErrorTooLong"],
        _ => L["Auth_ErrorGeneric"]
    };
}
