@page "/account/password"
@attribute [Authorize]
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Auth_ChangePageTitle"]</PageTitle>

<section class="page-heading compact">
    <div>
        <p class="kicker">ACCOUNT</p>
        <PageHeadingTitle Icon="settings">@L["Auth_ChangeTitle"]</PageHeadingTitle>
        <p>@L["Auth_ChangeDescription"]</p>
    </div>
    <RadzenButton Text="@L["Auth_BackToSettings"]" Icon="arrow_back" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Text" Click="@BackToSettings" />
</section>

<RadzenCard class="account-card">
    @if (Changed)
    {
        <div class="message-box success">@L["Auth_ChangeSuccess"]</div>
    }
    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="message-box error" role="alert">@ErrorText(Error)</div>
    }
    <form method="post" action="/auth/change-password" class="auth-form">
        <AntiforgeryToken />
        <div class="form-field">
            <label for="current-password">@L["Auth_CurrentPassword"]</label>
            <input id="current-password" class="auth-input" name="currentPassword" type="password" autocomplete="current-password" required autofocus />
        </div>
        <div class="form-field">
            <label for="new-password">@L["Auth_NewPassword"]</label>
            <input id="new-password" class="auth-input" name="password" type="password" minlength="12" maxlength="128" autocomplete="new-password" required />
            <small>@L["Auth_PasswordRule"]</small>
        </div>
        <div class="form-field">
            <label for="new-password-confirmation">@L["Auth_ConfirmPassword"]</label>
            <input id="new-password-confirmation" class="auth-input" name="confirmation" type="password" minlength="12" maxlength="128" autocomplete="new-password" required />
        </div>
        <button class="auth-primary" type="submit">@L["Auth_ChangeAction"]</button>
    </form>
</RadzenCard>

@code {
    [SupplyParameterFromQuery(Name = "changed")] private bool Changed { get; set; }
    [SupplyParameterFromQuery] private string? Error { get; set; }

    private void BackToSettings() => Navigation.NavigateTo("/settings");

    private string ErrorText(string code) => code switch
    {
        "current_password_invalid" => L["Auth_ErrorCurrentInvalid"],
        "password_mismatch" => L["Auth_ErrorMismatch"],
        "password_too_short" => L["Auth_ErrorTooShort"],
        "password_too_long" => L["Auth_ErrorTooLong"],
        _ => L["Auth_ErrorGeneric"]
    };
}
