@page "/"
@attribute [Authorize]
@using SyncCoordinator.Contracts
@using SyncCoordinator.Core
@inject ICoordinatorReadService ReadService
@inject IManagementSettingsService SettingsService
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Home_PageTitle"]</PageTitle>

<section class="page-heading dashboard-heading" data-testid="dashboard-page">
    <div>
        <p class="kicker">SYNC OVERVIEW</p>
        <PageHeadingTitle Icon="dashboard">@L["Home_Title"]</PageHeadingTitle>
        <p>@L["Home_Description"]</p>
    </div>
    <RadzenButton Text="@(loading ? L["Action_Refreshing"] : L["Action_Reload"])" Icon="refresh" Click="@LoadAsync" Disabled="@loading" />
</section>

@if (summary is null)
{
    <div class="loading-state"><RadzenProgressBar Mode="ProgressBarMode.Indeterminate" ShowValue="false" Style="width: 8rem" /><span>@L["Home_Loading"]</span></div>
}
else
{
    <section class="sync-board" aria-labelledby="sync-board-title">
        <div class="sync-board-header">
            <h2 id="sync-board-title">@L["Home_SyncStatus"]</h2>
            <ul class="sync-board-legend" aria-label="@L["Common_Legend"]">
                <li><span class="sync-legend-line enabled" aria-hidden="true"></span>@L["Home_Syncing"]</li>
                <li><span class="sync-legend-line held" aria-hidden="true"></span>@L["Home_Paused"]</li>
                <li><span class="sync-legend-line disabled" aria-hidden="true"></span>@L["Common_Excluded"]</li>
            </ul>
        </div>
        @if (routes.Count == 0)
        {
            <p class="sync-board-empty">@L["Home_NoRoutes"]</p>
        }
        else
        {
            <div class="sync-wire-list">
                @foreach (var route in routes)
                {
                    <div class="sync-wire-row">
                        <div class="sync-terminal" title="@L["Home_SourceTitle", route.SourceSystemName]">
                            <span class="sync-terminal-icon"><RadzenIcon Icon="dns" aria-hidden="true" /></span>
                            <span class="sync-terminal-copy">
                                <small>@L["Home_Source"]</small>
                                <a class="sync-terminal-link" href="@SystemLink(route.SourceSystem)">@route.SourceSystemName</a>
                            </span>
                        </div>
                        <div class="sync-wire-track @WireClass(route)" title="@route.Name">
                            <i aria-hidden="true"></i>
                            <a class="sync-wire-label" href="/routes/@route.Id">@route.Name</a>
                        </div>
                        <div class="sync-terminal destination" title="@L["Home_DestinationTitle", route.DestinationSystemName]">
                            <span class="sync-terminal-icon"><RadzenIcon Icon="dns" aria-hidden="true" /></span>
                            <span class="sync-terminal-copy">
                                <small>@L["Home_Destination"]</small>
                                <a class="sync-terminal-link" href="@SystemLink(route.DestinationSystem)">@route.DestinationSystemName</a>
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <section class="dashboard-metrics" aria-label="@L["Metric_Aria"]">
        <div class="dashboard-metric-group">
            <h2>@L["Metric_Targets"]</h2>
            <div class="dashboard-metric-grid targets">
                <RadzenCard class="metric-card target"><span>@L["Metric_EnabledSystems"]</span><strong><a class="metric-value-link" href="/systems" aria-label="@L["Metric_OpenCount", L["Metric_EnabledSystems"], summary.EnabledSystems]">@summary.EnabledSystems</a></strong></RadzenCard>
                <RadzenCard class="metric-card target"><span>@L["Metric_EnabledRoutes"]</span><strong><a class="metric-value-link" href="/routes" aria-label="@L["Metric_OpenCount", L["Metric_EnabledRoutes"], summary.EnabledRoutes]">@summary.EnabledRoutes</a></strong></RadzenCard>
            </div>
        </div>
        <div class="dashboard-metric-group">
            <h2>@L["Metric_ProcessingStatus"]</h2>
            <div class="dashboard-metric-grid processing">
                <RadzenCard class="metric-card processing"><span>@L["Metric_Processing"]</span><strong><a class="metric-value-link" href="/operations" aria-label="@L["Metric_OpenCount", L["Metric_Processing"], summary.ProcessingMessages]">@summary.ProcessingMessages</a></strong></RadzenCard>
                <RadzenCard class="metric-card retrying"><span>@L["Metric_Failed"]</span><strong><a class="metric-value-link" href="/operations" aria-label="@L["Metric_OpenCount", L["Metric_Failed"], summary.FailedMessages]">@summary.FailedMessages</a></strong></RadzenCard>
                <RadzenCard class="metric-card validation-error">
                    <div class="caption-title"><span>@L["Metric_ValueTransformationErrors"]</span><HelpTip Text="@L["Metric_ValueTransformationErrorsHelp"]" /></div>
                    <strong><a class="metric-value-link" href="/operations" aria-label="@L["Metric_OpenCount", L["Metric_ValueTransformationErrors"], summary.ValueTransformationErrors]">@summary.ValueTransformationErrors</a></strong>
                </RadzenCard>
                <RadzenCard class="metric-card attention">
                    <div class="caption-title"><span>@L["Metric_AttentionConflicts"]</span><HelpTip Text="@L["Metric_AttentionConflictsHelp"]" /></div>
                    <strong><a class="metric-value-link" href="/conflicts" aria-label="@L["Metric_OpenCount", L["Metric_AttentionConflicts"], summary.AttentionConflicts]">@summary.AttentionConflicts</a></strong>
                </RadzenCard>
            </div>
        </div>
    </section>

    <div class="content-stack">
        <RadzenCard class="dashboard-conflicts">
            <div class="panel-title">
                <div class="dashboard-section-title"><RadzenIcon Icon="history" aria-hidden="true" /><h2>@L["Home_RecentConflicts"]</h2></div>
                <RadzenButton Text="@L["Home_OpenHistory"]" Icon="arrow_forward" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Click="@OpenConflicts" />
            </div>
            <RadzenDataGrid Data="@conflicts" TItem="ConflictListItem" AllowSorting="true" AllowPaging="true" PageSize="10" EmptyText="@L["Home_NoConflicts"]" Density="Density.Compact">
                <Columns>
                    <RadzenDataGridColumn TItem="ConflictListItem" Property="Operation" Title="@L["Common_Type"]" Width="120px">
                        <Template Context="conflict">
                            <span class="conflict-kind @(conflict.Operation == ChangeOperation.Delete ? "delete" : "update")">
                                @(conflict.Operation == ChangeOperation.Delete ? L["ConflictDetail_DeleteConflict"] : L["ConflictDetail_UpdateConflict"])
                            </span>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="ConflictListItem" Property="DetectedAtUtc" Title="@L["Home_DetectedAt"]">
                        <Template Context="conflict">@UiFormat.LocalDateTime(conflict.DetectedAtUtc)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="ConflictListItem" Property="RouteName" Title="@L["Home_Rule"]">
                        <Template Context="conflict">@conflict.RouteName</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="ConflictListItem" Title="@L["Home_Direction"]" Sortable="false">
                        <Template Context="conflict"><code class="direction">@conflict.SourceSystemName → @conflict.DestinationSystemName</code></Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="ConflictListItem" Title="@L["Common_RecordKey"]" Sortable="false">
                        <Template Context="conflict"><a href="/conflicts/@conflict.Id">@conflict.EntityId</a></Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </div>
}

@code {
    [Inject] private NavigationManager Navigation { get; set; } = null!;

    private DashboardSummary? summary;
    private IReadOnlyList<RouteListItem> routes = [];
    private IReadOnlyList<ConflictListItem> conflicts = [];
    private bool loading;
    private bool globalPaused;

    protected override Task OnInitializedAsync() => LoadAsync();

    private void OpenConflicts() => Navigation.NavigateTo("/conflicts");

    private string StatusClass(RouteListItem route) => route.MappingMaintenance
        ? "held"
        : route.Enabled
            ? globalPaused || route.OperationallyPaused ? "held" : "enabled"
            : "disabled";

    private string WireClass(RouteListItem route) =>
        $"{(route.Direction == SyncDirection.Bidirectional ? "bidirectional" : "one-way")} {StatusClass(route)}";

    private static string SystemLink(string code) => $"/systems?code={Uri.EscapeDataString(code)}";

    private async Task LoadAsync()
    {
        loading = true;
        try
        {
            summary = await ReadService.GetSummaryAsync(CancellationToken.None);
            routes = await ReadService.GetRoutesAsync(CancellationToken.None);
            conflicts = await ReadService.GetRecentConflictsAsync(20, CancellationToken.None);
            globalPaused = (await SettingsService.GetAsync(CancellationToken.None)).GlobalPaused;
        }
        finally
        {
            loading = false;
        }
    }
}
