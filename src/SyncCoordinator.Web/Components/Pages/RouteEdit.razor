@page "/routes/new"
@page "/routes/{Id:guid}"
@attribute [Authorize]
@using SyncCoordinator.Core
@inject ICoordinatorAdminService AdminService
@inject IDatabaseDeploymentService DeploymentService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@inject UiErrorReporter ErrorReporter
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["RouteEdit_PageTitle"]</PageTitle>

<section class="page-heading compact">
    <div>
        <p class="kicker">CONFIGURATION</p>
        <PageHeadingTitle Icon="account_tree">@(Id is null ? L["RouteEdit_CreateTitle"] : L["RouteEdit_EditTitle"])</PageHeadingTitle>
        @if (Id is not null && !string.IsNullOrWhiteSpace(model.Name)) { <p>@model.Name</p> }
    </div>
    <RadzenButton Text="@L["Common_BackToList"]" Icon="arrow_back" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Text" Click="@BackToList" />
</section>

@if (Id is { } routeId)
{
    <RouteDetailTabs RouteId="@routeId" Active="settings" />
}

@if (loading)
{
    <div class="loading-state"><RadzenProgressBar Mode="ProgressBarMode.Indeterminate" ShowValue="false" Style="width: 8rem" /><span>@L["RouteEdit_Loading"]</span></div>
}
else
{
    <EditForm Model="model" OnSubmit="SaveAsync">
        <div class="content-stack">
            <RadzenCard>
                <div class="panel-title"><h2>@L["RouteEdit_BasicSettings"]</h2></div>
                <div class="form-grid">
                    <div class="form-field wide">
                        <label for="RouteName">@L["RouteEdit_RuleName"]</label>
                        <RadzenTextBox Name="RouteName" @bind-Value="model.Name" MaxLength="200" class="form-control" />
                    </div>
                    <div class="form-field">
                        <label for="SourceSystem">@L["RouteEdit_SourceSystem"]</label>
                        <RadzenDropDown Name="SourceSystem" TValue="string" @bind-Value="model.SourceSystem" Data="@systems" TextProperty="DisplayName" ValueProperty="Code" Placeholder="@L["Common_Select"]" AllowClear="true" class="form-control" />
                    </div>
                    <div class="form-field">
                        <label for="DestinationSystem">@L["RouteEdit_DestinationSystem"]</label>
                        <RadzenDropDown Name="DestinationSystem" TValue="string" @bind-Value="model.DestinationSystem" Data="@systems" TextProperty="DisplayName" ValueProperty="Code" Placeholder="@L["Common_Select"]" AllowClear="true" class="form-control" />
                    </div>
                    <div class="form-field wide">
                        <div class="caption-title"><label>@L["Routes_SyncDirection"]</label><HelpTip Text="@L["RouteEdit_DirectionHelp"]" /></div>
                        <InputRadioGroup TValue="SyncDirection" @bind-Value="model.Direction" class="direction-options">
                            <label class="direction-option">
                                <InputRadio TValue="SyncDirection" Value="SyncDirection.OneWay" />
                                <span><strong>@L["Common_OneWay"]</strong> @L["RouteEdit_OneWayDescription"]</span>
                            </label>
                            <label class="direction-option">
                                <InputRadio TValue="SyncDirection" Value="SyncDirection.Bidirectional" />
                                <span><strong>@L["Common_Bidirectional"]</strong> @L["RouteEdit_BidirectionalDescription"]</span>
                            </label>
                        </InputRadioGroup>
                    </div>
                    <div class="form-field">
                        <label for="ConflictScope">@L["RouteEdit_ConflictScope"]</label>
                        <RadzenDropDown Name="ConflictScope" TValue="ConflictScope" @bind-Value="model.ConflictScope" Data="@conflictScopes" TextProperty="Text" ValueProperty="Value" class="form-control" />
                    </div>
                    <div class="form-field">
                        <div class="caption-title"><label for="DefaultPolicy">@L["RouteEdit_DefaultPolicy"]</label><HelpTip Text="@L["RouteEdit_PolicyHelp"]" /></div>
                        <RadzenDropDown Name="DefaultPolicy" TValue="ConflictPolicy" @bind-Value="model.DefaultConflictPolicy" Data="@conflictPolicies" TextProperty="Text" ValueProperty="Value" class="form-control" />
                    </div>
                    @if (model.DeploymentState != DatabaseDeploymentState.Prepared)
                    {
                        <div class="info-note deployment-warning wide">@L["RouteEdit_DeploymentNote"]</div>
                    }
                </div>
                @if (Id is not null)
                {
                    <section class="route-activation">
                        <div class="route-activation-status">
                            <span>@L["RouteEdit_RuleStatus"]</span>
                            <strong class="status-pill @(model.Enabled ? "enabled" : "disabled")">@(model.Enabled ? L["Common_SyncTarget"] : L["RouteEdit_Excluded"])</strong>
                        </div>
                        <RadzenButton Text="@(changingEnabled ? L["Common_Processing"] : model.Enabled ? L["RouteEdit_DisableRule"] : L["RouteEdit_EnableRule"])"
                                      Icon="@(model.Enabled ? "toggle_off" : "toggle_on")"
                                      ButtonStyle="@(model.Enabled ? ButtonStyle.Warning : ButtonStyle.Primary)"
                                      ButtonType="ButtonType.Button"
                                      Disabled="@(changingEnabled || (!model.Enabled && model.DeploymentState != DatabaseDeploymentState.Prepared))"
                                      Click="@(() => SetEnabledAsync(!model.Enabled))" />
                    </section>
                }
            </RadzenCard>

        </div>

        <div class="form-actions page-actions">
            <RadzenButton Text="@(saving ? L["Common_Saving"] : L["RouteEdit_SaveSettings"])" Icon="save" ButtonType="ButtonType.Submit" Disabled="@saving" />
            <RadzenButton Text="@L["Common_Cancel"]" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@BackToList" />
        </div>
    </EditForm>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private SelectionOption<ConflictScope>[] conflictScopes =>
    [
        new(ConflictScope.Field, L["Common_FieldScope"]),
        new(ConflictScope.Record, L["Common_RecordScope"])
    ];
    private SelectionOption<ConflictPolicy>[] conflictPolicies =>
    [
        new(ConflictPolicy.HoldAndNotify, L["Common_Hold"]),
        new(ConflictPolicy.ApplyIncomingAndNotify, L["Common_UseSource"]),
        new(ConflictPolicy.KeepCurrentAndNotify, L["Common_KeepDestination"]),
        new(ConflictPolicy.MergeAndNotify, L["Common_Merge"])
    ];
    private RouteConfigurationInput model = NewModel();
    private IReadOnlyList<SystemListItem> systems = [];
    private bool loading = true;
    private bool saving;
    private bool changingEnabled;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        systems = await AdminService.GetSystemsAsync(CancellationToken.None);
        model = Id is null
            ? NewModel()
            : await AdminService.GetRouteAsync(Id.Value, CancellationToken.None) ?? NewModel();
        loading = false;
    }

    private void BackToList() => Navigation.NavigateTo("/routes");

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var routeId = await AdminService.SaveRouteAsync(model, CancellationToken.None);
            NotificationService.ShowSuccess(L["RouteEdit_Saved"], L["Common_Completed"]);
            if (Id is null)
            {
                Navigation.NavigateTo($"/routes/{routeId}");
            }
        }
        catch (ConfigurationValidationException exception)
        {
            NotificationService.ShowError(exception.Errors, L["Common_OperationFailed"]);
        }
        catch (Exception exception)
        {
            await ErrorReporter.ReportAsync(exception, "RouteEdit.Save");
            NotificationService.ShowError([exception.Message], L["Common_OperationFailed"]);
        }
        finally
        {
            saving = false;
        }
    }

    private async Task SetEnabledAsync(bool enabled)
    {
        if (Id is null) return;
        changingEnabled = true;
        try
        {
            var result = await DeploymentService.SetEnabledAsync(Id.Value, enabled, CancellationToken.None);
            model.Enabled = result.Enabled;
            model.DeploymentState = result.State;
            NotificationService.ShowSuccess(Display(result.Message), L["Common_Completed"]);
        }
        catch (Exception exception)
        {
            if (exception is not ConfigurationValidationException)
            {
                await ErrorReporter.ReportAsync(exception, "RouteEdit.SetEnabled");
            }
            NotificationService.ShowError(
                exception is ConfigurationValidationException validation ? validation.Errors : [exception.Message],
                L["Common_OperationFailed"]);
        }
        finally
        {
            changingEnabled = false;
        }
    }

    private string Display(DisplayText text) =>
        L[text.ResourceKey, text.Arguments.Select(value => (object)value).ToArray()];

    private static RouteConfigurationInput NewModel() => new()
    {
        Direction = SyncDirection.OneWay,
        ConflictScope = ConflictScope.Field,
        DefaultConflictPolicy = ConflictPolicy.HoldAndNotify,
        Enabled = false,
        DeploymentState = DatabaseDeploymentState.Draft
    };

    private sealed record SelectionOption<T>(T Value, string Text);
}
