@page "/Error"
@attribute [AllowAnonymous]
@using System.Diagnostics
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Error_PageTitle"]</PageTitle>

<RadzenCard>
    <RadzenStack Gap="1rem">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
            <RadzenIcon Icon="error" Style="font-size: 2rem; color: var(--rz-danger);" />
            <RadzenText TextStyle="TextStyle.H4">@L["Error_Title"]</RadzenText>
        </RadzenStack>
        <RadzenText TextStyle="TextStyle.Body1">@L["Error_Description"]</RadzenText>
        @if (ShowRequestId)
        {
            <div>Request ID: <code>@RequestId</code></div>
        }
    </RadzenStack>
</RadzenCard>

@code {
    [CascadingParameter] private HttpContext? HttpContext { get; set; }
    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() => RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
