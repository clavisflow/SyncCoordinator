@page "/conflicts/{Id:guid}"
@attribute [Authorize]
@using System.Text.Json.Nodes
@using SyncCoordinator.Core
@inject ICoordinatorAdminService AdminService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["ConflictDetail_PageTitle"]</PageTitle>

@if (details is null)
{
    <div class="loading-state"><RadzenProgressBar Mode="ProgressBarMode.Indeterminate" ShowValue="false" Style="width: 8rem" /><span>@L["ConflictDetail_Loading"]</span></div>
}
else
{
    <section class="page-heading compact">
        <div>
            <p class="kicker">CONFLICT DETAIL</p>
            <h1>@L["ConflictDetail_Target", details.EntityId]</h1>
            <p>@details.RouteName</p>
        </div>
        <RadzenButton Text="@L["Common_BackToList"]" Icon="arrow_back" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Text" Click="@BackToList" />
    </section>

    <div class="content-stack">
        <section class="detail-grid">
        <RadzenCard class="detail-card"><span>@L["Common_Direction"]</span><strong>@details.SourceSystemName → @details.DestinationSystemName</strong></RadzenCard>
        <RadzenCard class="detail-card"><span>@L["Common_Scope"]</span><strong>@ScopeText(details.Scope)</strong></RadzenCard>
        <RadzenCard class="detail-card"><span>@L["Common_DetectedAt"]</span><strong>@UiFormat.LocalDateTime(details.DetectedAtUtc)</strong></RadzenCard>
        <RadzenCard class="detail-card"><span>@L["Common_Status"]</span><strong><span class="status-pill @(details.ResolvedAtUtc is null ? "held" : "enabled")">@(details.ResolvedAtUtc is null ? L["Common_Unresolved"] : L["Common_Resolved"])</span></strong></RadzenCard>
        </section>

        <RadzenCard>
            <dl class="metadata-list">
                <dt>@L["ConflictDetail_SourceMessageId"]</dt><dd><code>@details.SourceMessageId</code></dd>
                <dt>@L["ConflictDetail_DeliveryMessageId"]</dt><dd><code>@details.DeliveryMessageId</code></dd>
            </dl>
        </RadzenCard>

        <RadzenCard>
        <div class="panel-title"><h2>@L["ConflictDetail_Fields"]</h2><span>@L["Common_ItemCount", details.Fields.Count]</span></div>
        <RadzenDataGrid Data="@details.Fields" TItem="FieldConflict" AllowSorting="true" EmptyText="@L["ConflictDetail_Empty"]" Density="Density.Compact">
                <Columns>
                <RadzenDataGridColumn TItem="FieldConflict" Property="FieldName" Title="@L["Common_Field"]" Frozen="true" />
                <RadzenDataGridColumn TItem="FieldConflict" Title="@L["ConflictDetail_Previous"]" Sortable="false"><Template Context="field"><pre class="json-value">@Format(field.BaseValue)</pre></Template></RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="FieldConflict" Title="@L["ConflictDetail_Incoming"]" Sortable="false"><Template Context="field"><pre class="json-value">@Format(field.IncomingValue)</pre></Template></RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="FieldConflict" Title="@L["ConflictDetail_Current"]" Sortable="false"><Template Context="field"><pre class="json-value">@Format(field.CurrentValue)</pre></Template></RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FieldConflict" Title="@L["ConflictDetail_Adopted"]" Sortable="false"><Template Context="field"><pre class="json-value adopted">@Format(field.AdoptedValue)</pre></Template></RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FieldConflict" Property="Policy" Title="@L["Common_Policy"]"><Template Context="field">@PolicyText(field.Policy)</Template></RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FieldConflict" Property="Resolution" Title="@L["Common_Result"]"><Template Context="field">@ResolutionText(field.Resolution)</Template></RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private ConflictDetails? details;

    protected override async Task OnParametersSetAsync() => details = await AdminService.GetConflictAsync(Id, CancellationToken.None);

    private void BackToList() => Navigation.NavigateTo("/conflicts");
    private static string Format(JsonNode? value) => value?.ToJsonString() ?? "null";
    private string ScopeText(ConflictScope scope) => scope == ConflictScope.Field ? L["Common_FieldScope"] : L["Common_RecordScope"];
    private string PolicyText(ConflictPolicy policy) => policy switch
    {
        ConflictPolicy.ApplyIncomingAndNotify => L["Common_UseSource"],
        ConflictPolicy.KeepCurrentAndNotify => L["Common_KeepDestination"],
        ConflictPolicy.MergeAndNotify => L["Common_Merge"],
        ConflictPolicy.HoldAndNotify => L["Common_Hold"],
        _ => policy.ToString()
    };

    private string ResolutionText(string resolution) => resolution switch
    {
        "KeptCurrent" => L["Common_KeepDestination"],
        "AppliedIncoming" => L["Common_UseSource"],
        "Merged" => L["Common_Merge"],
        "Held" => L["Common_Hold"],
        "MergeUnavailableHeld" => L["ConflictDetail_MergeUnavailableHeld"],
        "RecordHeld" => L["ConflictDetail_RecordHeld"],
        "AppliedIncomingDelete" => L["ConflictDetail_DeleteApplied"],
        "DeleteKeptCurrent" => L["ConflictDetail_DeleteKeptCurrent"],
        "DeleteHeld" => L["ConflictDetail_DeleteHeld"],
        "DeleteMergeUnavailableHeld" => L["ConflictDetail_DeleteMergeUnavailableHeld"],
        _ => resolution
    };
}
