@page "/conflicts"
@attribute [Authorize]
@using SyncCoordinator.Core
@inject ICoordinatorReadService ReadService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Conflicts_PageTitle"]</PageTitle>

<section class="page-heading">
    <div>
        <p class="kicker">HISTORY</p>
        <h1>@L["Conflicts_Title"]</h1>
        <p>@L["Conflicts_Description"]</p>
    </div>
    <RadzenButton Text="@(loading ? L["Action_Refreshing"] : L["Action_Reload"])" Icon="refresh" Click="@LoadAsync" Disabled="@loading" />
</section>

<RadzenCard>
    <div class="panel-title"><h2>@L["Conflicts_Recent"]</h2><span>@L["Common_Count", conflicts.Count]</span></div>
    <RadzenDataGrid Data="@conflicts" TItem="ConflictListItem" AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Simple" AllowPaging="true" PageSize="25" ShowPagingSummary="true" PagingSummaryFormat="@L["Common_PagingSummary"]" EmptyText="@L["Conflicts_Empty"]" Density="Density.Compact">
        <Columns>
            <RadzenDataGridColumn TItem="ConflictListItem" Property="DetectedAtUtc" Title="@L["Common_DetectedAt"]">
                <Template Context="conflict">@UiFormat.LocalDateTime(conflict.DetectedAtUtc)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ConflictListItem" Property="RouteName" Title="@L["Common_Rule"]" />
            <RadzenDataGridColumn TItem="ConflictListItem" Title="@L["Common_Direction"]" Sortable="false" Filterable="false">
                <Template Context="conflict"><code class="direction">@conflict.SourceSystemName → @conflict.DestinationSystemName</code></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ConflictListItem" Property="EntityId" Title="@L["Common_TargetId"]" />
            <RadzenDataGridColumn TItem="ConflictListItem" Property="Resolved" Title="@L["Common_Status"]" Width="100px">
                <Template Context="conflict"><span class="status-pill @(conflict.Resolved ? "enabled" : "held")">@(conflict.Resolved ? L["Common_Resolved"] : L["Common_Unresolved"])</span></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ConflictListItem" Title="" Sortable="false" Filterable="false" Width="72px" TextAlign="TextAlign.Right">
                <Template Context="conflict"><RadzenButton Icon="open_in_new" title="@L["Common_Details"]" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Size="ButtonSize.Small" Click="@(() => OpenDetails(conflict.Id))" /></Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenCard>

@code {
    private IReadOnlyList<ConflictListItem> conflicts = [];
    private bool loading;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        loading = true;
        try
        {
            conflicts = await ReadService.GetRecentConflictsAsync(200, CancellationToken.None);
        }
        finally
        {
            loading = false;
        }
    }

    private void OpenDetails(Guid id) => Navigation.NavigateTo($"/conflicts/{id}");
}
