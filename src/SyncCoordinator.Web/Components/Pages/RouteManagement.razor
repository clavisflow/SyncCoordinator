@page "/routes"
@attribute [Authorize]
@using SyncCoordinator.Core
@inject ICoordinatorReadService ReadService
@inject IManagementSettingsService SettingsService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Routes_PageTitle"]</PageTitle>

<section class="page-heading">
    <div>
        <p class="kicker">CONFIGURATION</p>
        <PageHeadingTitle Icon="account_tree">@L["Routes_Title"]</PageHeadingTitle>
        <p>@L["Routes_Description"]</p>
    </div>
    <RadzenButton Text="@L["Routes_New"]" Icon="add" Click="@CreateRoute" />
</section>

<RadzenCard>
    <div class="panel-title"><h2>@L["Routes_Registered"]</h2><span>@L["Common_Count", routes.Count]</span></div>
    <RadzenDataGrid Data="@routes" TItem="RouteListItem" AllowSorting="true" AllowPaging="true" PageSize="20" EmptyText="@L["Routes_Empty"]" Density="Density.Compact">
        <Columns>
            <RadzenDataGridColumn TItem="RouteListItem" Property="Name" Title="@L["Common_Rule"]" />
            <RadzenDataGridColumn TItem="RouteListItem" Title="@L["Common_SyncPath"]" Sortable="false" Filterable="false">
                <Template Context="route"><code class="direction">@route.SourceSystemName @(route.Direction == SyncDirection.Bidirectional ? "⇄" : "→") @route.DestinationSystemName</code><br /><small>@(route.Direction == SyncDirection.Bidirectional ? L["Common_Bidirectional"] : L["Common_OneWay"])</small></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="RouteListItem" Title="@L["Routes_ConflictSettings"]" Sortable="false" Filterable="false">
                <Template Context="route">@ConflictScopeText(route.ConflictScope) / @ConflictPolicyText(route.ConflictPolicy)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="RouteListItem" Property="Enabled" Title="@L["Common_SyncStatus"]" Width="150px">
                <Template Context="route"><span class="status-pill @StatusClass(route)">@StatusText(route)</span></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="RouteListItem" Property="DeploymentState" Title="@L["Common_DatabaseStatus"]" Width="160px">
                <Template Context="route"><span class="status-pill @DatabaseStatusClass(route)">@DatabaseStatusText(route)</span></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="RouteListItem" Title="" Sortable="false" Filterable="false" Width="70px" TextAlign="TextAlign.Right">
                <Template Context="route">
                    <RadzenButton Icon="edit" title="@L["Common_Edit"]" aria-label="@L["Common_Edit"]" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Size="ButtonSize.Small" Click="@(() => EditRoute(route.Id))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenCard>

@code {
    private IReadOnlyList<RouteListItem> routes = [];
    private bool globalPaused;

    protected override async Task OnInitializedAsync()
    {
        routes = await ReadService.GetRoutesAsync(CancellationToken.None);
        globalPaused = (await SettingsService.GetAsync(CancellationToken.None)).GlobalPaused;
    }

    private void CreateRoute() => Navigation.NavigateTo("/routes/new");
    private void EditRoute(Guid id) => Navigation.NavigateTo($"/routes/{id}");

    private string StatusText(RouteListItem route) => route.MappingMaintenance
        ? L["Common_MappingMaintenance"]
        : route.Enabled
            ? globalPaused || route.OperationallyPaused ? L["Common_Paused"] : L["Common_SyncTarget"]
            : L["Common_Excluded"];

    private string StatusClass(RouteListItem route) => route.MappingMaintenance
        ? "held"
        : route.Enabled
            ? globalPaused || route.OperationallyPaused ? "held" : "enabled"
            : "disabled";

    private string DatabaseStatusText(RouteListItem route) => route.DeploymentState == DatabaseDeploymentState.Prepared
        ? L["Common_DbPrepared"]
        : L["Common_Draft"];

    private static string DatabaseStatusClass(RouteListItem route) =>
        route.DeploymentState == DatabaseDeploymentState.Prepared ? "prepared" : "disabled";

    private string ConflictScopeText(ConflictScope scope) =>
        scope == ConflictScope.Field ? L["Common_FieldScope"] : L["Common_RecordScope"];

    private string ConflictPolicyText(ConflictPolicy policy) => policy switch
    {
        ConflictPolicy.HoldAndNotify => L["Common_Hold"],
        ConflictPolicy.ApplyIncomingAndNotify => L["Common_UseSource"],
        ConflictPolicy.KeepCurrentAndNotify => L["Common_KeepDestination"],
        ConflictPolicy.MergeAndNotify => L["Common_Merge"],
        _ => policy.ToString()
    };
}
