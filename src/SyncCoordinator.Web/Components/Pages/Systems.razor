@page "/systems"
@attribute [Authorize]
@using SyncCoordinator.Core
@inject ICoordinatorAdminService AdminService
@inject IManagementSettingsService SettingsService
@inject IDatabaseMetadataService MetadataService
@inject NotificationService NotificationService
@inject UiErrorReporter ErrorReporter
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Systems_PageTitle"]</PageTitle>

<section class="page-heading">
    <div>
        <p class="kicker">CONFIGURATION</p>
        <PageHeadingTitle Icon="dns">@L["Systems_Title"]</PageHeadingTitle>
        <p>@L["Systems_Description"]</p>
    </div>
    <RadzenButton Text="@L["Systems_New"]" Icon="add" Click="@StartCreate" />
</section>

<div class="split-layout">
    <RadzenCard>
        <div class="panel-title"><h2>@L["Systems_Registered"]</h2><span>@L["Common_Count", systems.Count]</span></div>
        <div class="@("systems-global-control" + (globalPaused ? " paused" : string.Empty))">
            <div class="systems-global-state">
                <div class="caption-title">
                    <strong>@L["Systems_AllSynchronization"]</strong>
                    @if (globalPaused)
                    {
                        <HelpTip Text="@L["Systems_GlobalPauseHelp"]" />
                    }
                </div>
                <span class="status-pill @(globalPaused ? "held" : "enabled")">@(globalPaused ? L["Systems_GlobalPaused"] : L["Systems_IndividualControl"])</span>
            </div>
            <RadzenButton Text="@(globalPaused ? L["Systems_ResumeAll"] : L["Systems_PauseAll"])"
                          Icon="@(globalPaused ? "play_circle" : "pause_circle")"
                          ButtonStyle="@(globalPaused ? ButtonStyle.Success : ButtonStyle.Warning)"
                          Variant="Variant.Outlined"
                          Size="ButtonSize.Small"
                          Disabled="@changingGlobalPause"
                          Click="@SetGlobalPausedAsync" />
        </div>
        <RadzenDataGrid Data="@systems" TItem="SystemListItem" AllowSorting="true" AllowPaging="true" PageSize="15" EmptyText="@L["Systems_Empty"]" Density="Density.Compact">
            <Columns>
                <RadzenDataGridColumn TItem="SystemListItem" Property="Code" Title="@L["Systems_Code"]" Width="110px">
                    <Template Context="system"><code>@system.Code</code></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SystemListItem" Property="DisplayName" Title="@L["Systems_DisplayName"]" />
                <RadzenDataGridColumn TItem="SystemListItem" Property="Provider" Title="@L["Systems_DatabaseType"]" Width="130px">
                    <Template Context="system">@ProviderDisplayName(system.Provider)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SystemListItem" Property="Enabled" Title="@L["Common_Status"]" Width="110px">
                    <Template Context="system"><span class="status-pill @SystemStatusClass(system)">@SystemStatusText(system)</span></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SystemListItem" Property="ConnectionConfigured" Title="@L["Systems_DbConnection"]" Width="100px">
                    <Template Context="system"><span class="status-pill @(system.ConnectionConfigured ? "enabled" : "held")">@(system.ConnectionConfigured ? L["Common_Configured"] : L["Common_NotConfigured"])</span></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SystemListItem" Title="" Sortable="false" Filterable="false" Width="112px" TextAlign="TextAlign.Right">
                    <Template Context="system">
                        <RadzenButton Icon="@(system.IsPaused ? "play_circle" : "pause_circle")"
                                      title="@(system.IsPaused ? L["Systems_Resume"] : L["Systems_Pause"])"
                                      aria-label="@(system.IsPaused ? L["Systems_Resume"] : L["Systems_Pause"])"
                                      ButtonStyle="@(system.IsPaused ? ButtonStyle.Success : ButtonStyle.Warning)"
                                      Variant="Variant.Text"
                                      Size="ButtonSize.Small"
                                      Disabled="@(globalPaused || !system.Enabled || pausingSystemId is not null)"
                                      Click="@(() => SetPausedAsync(system))" />
                        <RadzenButton Icon="edit" title="@L["Common_Edit"]" aria-label="@L["Common_Edit"]" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Size="ButtonSize.Small" Click="@(() => StartEditAsync(system.Id))" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>

    <RadzenCard class="editor-panel">
        <div class="panel-title"><h2>@(editModel.Id is null ? L["Systems_Create"] : L["Systems_Edit"])</h2></div>
        <EditForm Model="editModel" OnSubmit="SaveAsync" class="form-stack">
            <div class="form-field">
                <div class="caption-title"><label for="SystemCode">@L["Systems_SystemCode"]</label><HelpTip Text="@L["Systems_SystemCodeHelp"]" /></div>
                <RadzenTextBox Name="SystemCode" @bind-Value="editModel.Code" Disabled="@(editModel.Id is not null)" MaxLength="64" class="form-control" />
            </div>
            <div class="form-field">
                <label for="DisplayName">@L["Systems_DisplayName"]</label>
                <RadzenTextBox Name="DisplayName" @bind-Value="editModel.DisplayName" MaxLength="200" class="form-control" />
            </div>
            <div class="form-field">
                <label for="Provider">@L["Systems_DatabaseType"]</label>
                <RadzenDropDown Name="Provider" TValue="string" @bind-Value="editModel.Provider" Data="@providers" TextProperty="Text" ValueProperty="Value" Change="@OnProviderChanged" class="form-control" />
            </div>
            <div class="check-row">
                <RadzenCheckBox Name="Enabled" TValue="bool" @bind-Value="editModel.Enabled" />
                <div class="caption-title">
                    <RadzenLabel Text="@L["Common_Enabled"]" Component="Enabled" />
                    <HelpTip Text="@L["Systems_DisableHelp"]" />
                </div>
            </div>
            <div class="section-divider"></div>
            <div class="panel-title"><div class="caption-title"><h2>@L["Systems_DbConnection"]</h2><HelpTip Text="@L["Systems_DbConnectionHelp"]" /></div></div>
            <div class="form-field">
                <label for="DbServer">@L["Systems_Server"]</label>
                <RadzenTextBox Name="DbServer" @bind-Value="connectionModel.Server" class="form-control" />
            </div>
            <div class="form-field">
                <label for="DbPort">@L["Systems_Port"]</label>
                <RadzenNumeric Name="DbPort" TValue="int?" @bind-Value="connectionModel.Port" Min="1" Max="65535" class="form-control system-port-input" />
            </div>
            <div class="form-field">
                <label for="DbName">@L["Systems_Database"]</label>
                <RadzenTextBox Name="DbName" @bind-Value="connectionModel.Database" class="form-control" />
            </div>
            @if (editModel.Provider == "SqlServer")
            {
                <div class="check-row">
                    <RadzenCheckBox Name="IntegratedSecurity" TValue="bool" @bind-Value="connectionModel.IntegratedSecurity" />
                    <RadzenLabel Text="@L["Systems_WindowsAuth"]" Component="IntegratedSecurity" />
                </div>
            }
            @if (!connectionModel.IntegratedSecurity)
            {
                <div class="form-field">
                    <label for="DbUser">@L["Auth_UserName"]</label>
                    <RadzenTextBox Name="DbUser" @bind-Value="connectionModel.UserName" AutoComplete="off" class="form-control" />
                </div>
                <div class="form-field">
                    <label for="DbPassword">@L["Auth_Password"]</label>
                    <RadzenPassword Name="DbPassword" @bind-Value="connectionModel.Password" Placeholder="@(connectionModel.HasStoredPassword ? L["Systems_KeepPassword"] : L["Auth_Password"])" AutoComplete="new-password" class="form-control" />
                </div>
            }
            <div class="check-row">
                <RadzenCheckBox Name="DbEncrypt" TValue="bool" @bind-Value="connectionModel.Encrypt" />
                <RadzenLabel Text="@L["Systems_Encrypt"]" Component="DbEncrypt" />
            </div>
            @if (editModel.Provider is "SqlServer" or "PostgreSql")
            {
                <div class="check-row">
                    <RadzenCheckBox Name="TrustCertificate" TValue="bool" @bind-Value="connectionModel.TrustServerCertificate" />
                    <RadzenLabel Text="@L["Systems_TrustCertificate"]" Component="TrustCertificate" />
                </div>
            }
            <div class="form-actions">
                <RadzenButton Text="@(saving ? L["Common_Saving"] : L["Common_Save"])" Icon="save" ButtonType="ButtonType.Submit" Disabled="@(saving || testingConnection)" />
                <RadzenButton Text="@(testingConnection ? L["Systems_Testing"] : L["Systems_TestConnection"])" Icon="cable" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@TestConnectionAsync" Disabled="@(saving || testingConnection)" />
                <RadzenButton Text="@L["Common_Clear"]" Icon="restart_alt" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@StartCreate" Disabled="@(saving || testingConnection)" />
            </div>
        </EditForm>
    </RadzenCard>
</div>

@code {
    [Parameter, SupplyParameterFromQuery(Name = "code")] public string? RequestedSystemCode { get; set; }

    private static readonly ProviderOption[] providers =
    [
        new("SqlServer", "SQL Server"),
        new("MySql", "MySQL"),
        new("PostgreSql", "PostgreSQL")
    ];
    private IReadOnlyList<SystemListItem> systems = [];
    private SystemConfigurationInput editModel = NewModel();
    private DatabaseConnectionInput connectionModel = NewConnectionModel("SqlServer");
    private bool saving;
    private bool testingConnection;
    private bool globalPaused;
    private bool changingGlobalPause;
    private Guid? pausingSystemId;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        var requestedSystem = systems.FirstOrDefault(system =>
            string.Equals(system.Code, RequestedSystemCode, StringComparison.OrdinalIgnoreCase));
        if (requestedSystem is not null)
        {
            await StartEditAsync(requestedSystem.Id);
        }
    }

    private async Task LoadAsync()
    {
        systems = await AdminService.GetSystemsAsync(CancellationToken.None);
        globalPaused = (await SettingsService.GetAsync(CancellationToken.None)).GlobalPaused;
    }

    private async Task SetGlobalPausedAsync()
    {
        changingGlobalPause = true;
        var pause = !globalPaused;
        try
        {
            await SettingsService.SetGlobalPausedAsync(pause, CancellationToken.None);
            globalPaused = pause;
            NotificationService.ShowSuccess(
                pause ? L["Systems_AllPausedMessage"] : L["Systems_AllResumedMessage"],
                L["Common_Completed"]);
        }
        catch (Exception exception)
        {
            await ErrorReporter.ReportAsync(exception, "Systems.SetGlobalPaused");
            NotificationService.ShowError([exception.Message], L["Common_OperationFailed"]);
        }
        finally
        {
            changingGlobalPause = false;
        }
    }

    private void StartCreate()
    {
        editModel = NewModel();
        connectionModel = NewConnectionModel(editModel.Provider);
    }

    private async Task StartEditAsync(Guid id)
    {
        editModel = await AdminService.GetSystemAsync(id, CancellationToken.None) ?? NewModel();
        connectionModel = await AdminService.GetDatabaseConnectionAsync(id, CancellationToken.None) ?? NewConnectionModel(editModel.Provider, id);
    }

    private async Task SetPausedAsync(SystemListItem system)
    {
        pausingSystemId = system.Id;
        try
        {
            await AdminService.SetSystemPausedAsync(system.Id, !system.IsPaused, CancellationToken.None);
            await LoadAsync();
            NotificationService.ShowSuccess(
                system.IsPaused
                    ? L["Systems_ResumedMessage", system.DisplayName]
                    : L["Systems_PausedMessage", system.DisplayName],
                L["Common_Completed"]);
        }
        catch (ConfigurationValidationException exception)
        {
            NotificationService.ShowError(exception.Errors, L["Common_OperationFailed"]);
        }
        catch (Exception exception)
        {
            await ErrorReporter.ReportAsync(exception, "Systems.SetPaused");
            NotificationService.ShowError([exception.Message], L["Common_OperationFailed"]);
        }
        finally
        {
            pausingSystemId = null;
        }
    }

    private async Task SaveAsync()
    {
        saving = true;
        try
        {
            var connection = HasConnectionInput() ? connectionModel : null;
            var id = await AdminService.SaveSystemAsync(editModel, connection, CancellationToken.None);
            await LoadAsync();
            editModel = await AdminService.GetSystemAsync(id, CancellationToken.None) ?? NewModel();
            connectionModel = await AdminService.GetDatabaseConnectionAsync(id, CancellationToken.None) ?? NewConnectionModel(editModel.Provider, id);
            NotificationService.ShowSuccess(L["Systems_Saved"], L["Common_Completed"]);
        }
        catch (ConfigurationValidationException exception)
        {
            NotificationService.ShowError(exception.Errors, L["Common_OperationFailed"]);
        }
        catch (Exception exception)
        {
            await ErrorReporter.ReportAsync(exception, "Systems.Save");
            NotificationService.ShowError([exception.Message], L["Common_OperationFailed"]);
        }
        finally
        {
            saving = false;
        }
    }

    private async Task TestConnectionAsync()
    {
        testingConnection = true;
        try
        {
            var result = await MetadataService.TestConnectionAsync(editModel.Provider, connectionModel, CancellationToken.None);
            if (result.HasWarning)
            {
                NotificationService.ShowWarning(result.Message, L["Systems_ConnectionWarning"]);
            }
            else if (result.Success)
            {
                NotificationService.ShowSuccess(result.Message, L["Systems_ConnectionSucceeded"]);
            }
            else
            {
                NotificationService.ShowError([result.Message], L["Systems_ConnectionFailed"]);
            }
        }
        catch (Exception exception)
        {
            await ErrorReporter.ReportAsync(exception, "Systems.TestConnection");
            NotificationService.ShowError([exception.Message], L["Systems_ConnectionFailed"]);
        }
        finally
        {
            testingConnection = false;
        }
    }

    private void OnProviderChanged(object? value)
    {
        var provider = value?.ToString() ?? "SqlServer";
        editModel.Provider = provider;
        if (!connectionModel.HasStoredPassword &&
            string.IsNullOrWhiteSpace(connectionModel.Server) &&
            string.IsNullOrWhiteSpace(connectionModel.Database))
        {
            connectionModel.Port = DefaultPort(provider);
        }
        if (provider != "SqlServer")
        {
            connectionModel.IntegratedSecurity = false;
            connectionModel.TrustServerCertificate = false;
        }
    }

    private bool HasConnectionInput() =>
        connectionModel.HasStoredPassword ||
        !string.IsNullOrWhiteSpace(connectionModel.Server) ||
        !string.IsNullOrWhiteSpace(connectionModel.Database) ||
        !string.IsNullOrWhiteSpace(connectionModel.UserName) ||
        !string.IsNullOrEmpty(connectionModel.Password) ||
        connectionModel.IntegratedSecurity ||
        connectionModel.TrustServerCertificate ||
        !connectionModel.Encrypt ||
        connectionModel.Port != DefaultPort(editModel.Provider);

    private static SystemConfigurationInput NewModel() => new() { Provider = "SqlServer", Enabled = true };

    private string SystemStatusText(SystemListItem system) =>
        !system.Enabled
            ? L["Common_Disabled"]
            : globalPaused
                ? L["Systems_PausedByGlobal"]
                : system.IsPaused
                    ? L["Common_Paused"]
                    : L["Common_Running"];

    private string SystemStatusClass(SystemListItem system) =>
        !system.Enabled ? "disabled" : globalPaused || system.IsPaused ? "held" : "enabled";

    private static DatabaseConnectionInput NewConnectionModel(string provider, Guid systemId = default) => new()
    {
        SystemId = systemId,
        Port = DefaultPort(provider),
        Encrypt = true
    };

    private static int DefaultPort(string provider) => provider switch
    {
        "MySql" => 3306,
        "PostgreSql" => 5432,
        _ => 1433
    };

    private static string ProviderDisplayName(string provider) => provider switch
    {
        "SqlServer" => "SQL Server",
        "MySql" => "MySQL",
        "PostgreSql" => "PostgreSQL",
        _ => provider
    };

    private sealed record ProviderOption(string Value, string Text);
}
