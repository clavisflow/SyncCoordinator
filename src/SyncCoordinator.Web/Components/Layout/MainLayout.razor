@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResource> L

<RadzenLayout>
    <RadzenHeader class="app-header">
        <div class="header-content">
            <div class="header-brand-zone">
                <RadzenSidebarToggle Click="@ToggleSidebar" />
                <a class="brand" href="/" aria-label="@L["Brand_DashboardAria"]">
                    <img class="brand-logo" src="images/branding/sync-coordinator-logo.png" alt="" />
                    <strong>SyncCoordinator</strong>
                </a>
            </div>
            <div class="header-utility">
                <CultureSelector />
                <a class="header-account-link" href="/account/password">@L["Account_ChangePassword"]</a>
                <form method="post" action="/auth/logout" class="logout-form">
                    <AntiforgeryToken />
                    <button type="submit">@L["Account_Logout"]</button>
                </form>
                <RadzenBadge Text="@Environment.EnvironmentName" BadgeStyle="BadgeStyle.Light" />
            </div>
        </div>
    </RadzenHeader>

    <RadzenSidebar @bind-Expanded="sidebarExpanded" class="app-sidebar">
        <nav class="app-navigation" aria-label="@L["Nav_Main"]">
            <section class="app-menu-section" aria-labelledby="nav-operations-heading">
                <h2 id="nav-operations-heading" class="app-menu-heading">@L["Nav_GroupOperations"]</h2>
                <RadzenPanelMenu Multiple="false" class="app-menu">
                    <RadzenPanelMenuItem Text="@L["Nav_Dashboard"]" Icon="dashboard" Path="/" />
                    <RadzenPanelMenuItem Text="@L["Nav_Operations"]" Icon="monitor_heart" Path="/operations" />
                    <RadzenPanelMenuItem Text="@L["Nav_Conflicts"]" Icon="rule" Path="/conflicts" />
                </RadzenPanelMenu>
            </section>
            <section class="app-menu-section" aria-labelledby="nav-configuration-heading">
                <h2 id="nav-configuration-heading" class="app-menu-heading">@L["Nav_GroupConfiguration"]</h2>
                <RadzenPanelMenu Multiple="false" class="app-menu">
                    <RadzenPanelMenuItem Text="@L["Nav_Systems"]" Icon="dns" Path="/systems" />
                    <RadzenPanelMenuItem Text="@L["Nav_Routes"]" Icon="account_tree" Path="/routes" />
                    <RadzenPanelMenuItem Text="@L["Nav_Webhooks"]" Icon="notifications" Path="/notifications" />
                </RadzenPanelMenu>
            </section>
        </nav>
    </RadzenSidebar>

    <RadzenBody>
        <main class="page-shell">
            @Body
        </main>
    </RadzenBody>
</RadzenLayout>

<RadzenComponents />

<div id="blazor-error-ui" data-nosnippet>
    @L["Error_Unexpected"]
    <a href="." class="reload">@L["Action_Reload"]</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    [Inject] private IWebHostEnvironment Environment { get; set; } = null!;

    private bool sidebarExpanded = true;

    private void ToggleSidebar() => sidebarExpanded = !sidebarExpanded;
}
